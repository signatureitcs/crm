# Supabase — copy to .env.local and fill in from your project's API settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the browser. Required for notifications
# (reading other users' push subscriptions) and the cron job.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Absolute site origin, used to build links in Teams cards / push payloads.
# e.g. http://localhost:3000 locally, or https://your-app.vercel.app in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Microsoft Teams -------------------------------------------------------
# Incoming Webhook / Power Automate "Workflow" URL for your team channel.
# Leave blank to disable Teams posts (the app still works).
TEAMS_WEBHOOK_URL=

# --- Web push (VAPID) ------------------------------------------------------
# Generate with:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# The public key is exposed to the browser; the private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@agency.com

# --- Cron (due-task reminders) ---------------------------------------------
# Any random string. Vercel Cron sends it as an Authorization: Bearer header.
CRON_SECRET=
